# ==========================================
# 1. 前端依赖与构建产物 (Vue/React/Angular)
# ==========================================

# 忽略 node_modules 目录 (核心)
node_modules/

# 忽略 npm 的调试日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 忽略构建产出目录 (通常是 dist 或 build)
dist/
build/
.output/

# VuePress / VitePress 默认输出目录
.docs/.vuepress/dist/

# ==========================================
# 2. Java 编译与打包 (Maven/Gradle)
# ==========================================

# Maven
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties

# Gradle
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar

# 通用 Java 编译产物
*.class
*.jar
*.war
*.ear
*.nar

# ==========================================
